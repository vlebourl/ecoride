# === Database ===
DATABASE_URL=postgresql://ecoride:ecoride@localhost:5432/ecoride
# Production (Docker Compose) : postgresql://ecoride:ecoride@postgres:5432/ecoride

# === Better Auth ===
BETTER_AUTH_SECRET=your-secret-key-here
# Generer avec : openssl rand -hex 32
BETTER_AUTH_URL=http://localhost:3000
# Production : https://ecoride.tiarkaerell.com

# === Google OAuth ===
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# === Web Push (VAPID) ===
# Generer avec : bunx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@tiarkaerell.com

# === Sentry (optional — client-side error tracking) ===
# Leave empty to disable. Set to your Sentry DSN to enable.
VITE_SENTRY_DSN=

# === App ===
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
# Production : https://ecoride.tiarkaerell.com
